# Cormes configuration
#
# Override the Cormes state directory.
# Default: %TEMP%\cormes
# CORMES_STATE_DIR=D:\path\to\custom\state
#
# Legacy alias, still accepted for compatibility:
# CODEX_HERMES_STATE_DIR=D:\path\to\custom\state
#
# Override the repository root used for repo-local state and relative lookups.
# CORMES_REPO_ROOT=D:\path\to\repo
#
# Legacy alias, still accepted for compatibility:
# CODEX_HERMES_REPO_ROOT=D:\path\to\repo
